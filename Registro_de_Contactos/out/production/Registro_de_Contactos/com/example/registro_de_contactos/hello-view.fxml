<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.registro_de_contactos.HelloController">
  <padding><Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/></padding>

  <GridPane vgap="10" hgap="10">
    <Label text="Nombre:"/> <TextField fx:id="txtNombre" GridPane.columnIndex="1"/>
    <Label text="Teléfono:" GridPane.rowIndex="1"/> <TextField fx:id="txtTelefono" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
    <Label text="Parentesco:" GridPane.rowIndex="2"/> <ComboBox fx:id="cbParentesco" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="150"/>
  </GridPane>

  <HBox spacing="5">
    <Button text="Agregar" onAction="#onAgregarClick"/>
    <Button text="Buscar" onAction="#onBuscarClick"/>
    <Button text="Actualizar" onAction="#onActualizarClick"/>
    <Button text="Eliminar" onAction="#onEliminarClick"/>
    <Button text="Limpiar" onAction="#onLimpiarClick"/>
  </HBox>

  <ListView fx:id="listView" VBox.vgrow="ALWAYS"/>
</VBox>